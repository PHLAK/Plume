{% extends "layouts/app.twig" %}

{% block content %}
    <div id="search-results" class="grow my-12">
        {% for result in results %}
            <div id="result" class="space-y-8">
                <h2 class="text-2xl font-light text-center text-stone-800 md:text-4xl dark:text-stone-200">
                    <a href="{{ url_for(result.type, { slug: result.id }) }}">
                        {{ result.title }}
                    </a>
                </h2>

                <article class="prose prose-stone prose-lg max-w-none line-clamp-5 text-ellipsis md:prose-xl dark:prose-invert">
                    {{ result.body | raw }}
                </article>
            </div>

            {% if loop.last == false  %}
                <hr class="border-t-4 border-stone-200 w-64 mx-auto my-12 dark:border-stone-600">
            {% endif %}
        {% endfor %}
    </div>
{% endblock %}
