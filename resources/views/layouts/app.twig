<!DOCTYPE html>

<html lang="{{ config('language') }}" x-data="application" x-effect="storeThemeCookie($store.theme)" :class="{
    'light': $store.theme === 'light' || ($store.theme === 'system' && systemTheme === 'light'),
    'dark': $store.theme === 'dark' || ($store.theme === 'system' && systemTheme === 'dark'),
}">

<meta charset="utf-8">
<meta name="description" content="{{ config('meta_description') }}">
<meta name="viewport" content="width=device-width, initial-scale=1">

<link rel="icon" href="/images/favicon.svg">

<script>
    window.systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';

    const [cookie, theme] = document.cookie.match(/theme=(dark|light)/) || [null, null];
    document.documentElement.classList.add(theme ?? window.systemTheme);
</script>

{{ vite(['resources/css/app.css', 'resources/js/app.js']) }}

{{ customizations() }}

<title>{% if title %}{{ title }} &bull; {% endif %}{{ config('site_title') }}</title>

<div class="flex flex-col min-h-screen">
    {% include 'components/header.twig' %}

    <div id="content" class="container flex flex-col grow max-w-5xl mx-auto px-4">
        {% block content %}{% endblock %}
    </div>

    {% include 'components/footer.twig' %}
</div>

{% include 'components/scroll-to-top.twig' %}

{% include 'components/search-modal.twig' %}
