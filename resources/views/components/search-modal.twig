<div x-data="searchModal" x-show="visible" @click.self="hide()" @keyup.escape.window="hide()"
    class="fixed inset-0 flex flex-col justify-start items-center bg-stone-800/50 px-4 z-50 dark:bg-stone-600/50"
    @show-search.window="show()" x-transition:enter.opacity x-cloak
>
    <div class="flex flex-col justify-start items-center gap-4 rounded bg-stone-200 max-w-2xl w-full mt-[20vh] p-4 shadow dark:bg-stone-800 dark:border-stone-400 dark:text-stone-400"
        @click.away="hide()" x-trap.inert="visible"
    >
        <form class="group relative block border border-stone-600 bg-stone-200 rounded w-full dark:bg-stone-800"
            @submit.prevent="submit()"
        >
            <input id="search" type="text" name="search" placeholder="Search" class="bg-transparent placeholder-stone-600 w-full px-10 py-2 focus:outline-none"
                x-model="query" @keyup.?.prevent.window="$el.focus()" @focus="$event.target.select()"
            >

            <div class="flex items-center absolute left-0 inset-y-0 ml-2 pointer-events-none">
                {{ svg('light/magnifying-glass', ['fill-current', 'size-6', 'text-stone-600']) }}
            </div>
        </form>

        <div class="flex gap-4 text-stone-800 dark:text-stone-400">
            <div class="flex items-center gap-1">
                <kbd>{{ svg('light/arrow-turn-down-left', ['fill-current', 'size-4']) }}</kbd>
                to search
            </div>

            <div class="flex items-center gap-1">
                <kbd class="text-xs">esc</kbd> to close
            </div>
        </div>
    </div>
</div>
