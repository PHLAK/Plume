<div class="fixed bottom-0 left-0 right-0 pointer-events-none" x-data="{ visible: false }"
    x-init="visible = window.scrollY > 10" x-show="visible" x-transition.opacity x-cloak
>
    <div class="container flex justify-end mx-auto px-4 py-10 xl:max-w-4xl">
        <button title="Scroll to Top" class="flex justify-center items-center w-12 h-12 right-0 rounded-full shadow-lg bg-stone-600 text-white cursor-pointer pointer-events-auto transition dark:bg-stone-600  hover:scale-110"
            @click="window.scrollTo({ top: 0, left: 0, behavior: 'smooth' });" @scroll.window="visible = window.scrollY > 10"
        >
            {{ svg('light/arrow-up', ['fill-current', 'size-6']) }}
        </button>
    </div>
</div>
