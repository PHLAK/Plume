<div class="fixed bottom-0 left-0 right-0 pointer-events-none" x-data="{ visible: false }"
    x-init="visible = window.scrollY > document.getElementById('content').offsetTop" x-show="visible" x-transition x-cloak
>
    <div class="container max-w-4xl flex justify-center items-end mx-auto py-2 xl:max-w-4xl">
        <button title="Scroll to Top" class="flex justify-center items-center rounded border border-stone-600 bg-stone-100 shadow font-medium text-stone-600 cursor-pointer pointer-events-auto transition px-4 py-2 hover:bg-stone-200 dark:bg-stone-800 dark:border-stone-400 dark:text-stone-400 dark:hover:bg-stone-700"
            @click="window.scrollTo({ top: 0, left: 0, behavior: 'smooth' });" @scroll.window="visible = window.scrollY > document.getElementById('content').offsetTop"
        >
            Back to top
        </button>
    </div>
</div>
