{% set pages = pages() %}

<header>
    <div class="container max-w-4xl text-center mx-auto px-4 py-8">
        <a href="{{ url_for('posts') }}" class="inline-block text-stone-800">
            <span class="font-serif font-extralight text-4xl md:text-6xl dark:text-stone-200">{{ config('site_title') }}</span>
        </a>
    </div>
</header>

<div x-data="{ open: false }">
    <div class="flex justify-between items-center">
        <div class="container max-w-4xl flex justify-between items-center gap-1.5 border-double border-stone-800 border-t-4 border-b-4 text-stone-800 mx-auto px-4 py-2 dark:border-stone-200 dark:text-stone-200">
            <div class="flex justify-between items-center gap-1.5">
                <div class="flex items-center gap-1.5">
                    <a href="{{ full_url_for('posts') }}" title="Home" class="nav-button">
                        {{ svg('light/home', ['fill-current', 'size-6']) }}
                    </a>

                    {% if tags_enabled %}
                        <a href="/tags" title="Tags" class="nav-button">
                            {{ svg('light/tags', ['fill-current', 'size-6']) }}
                        </a>
                    {% endif %}

                    {% if authors_enabled %}
                        <a href="{{ url_for('authors') }}" title="Authors" class="nav-button">
                            {{ svg('light/user-group', ['fill-current', 'size-6']) }}
                        </a>
                    {% endif %}

                    <button @click="open = !open" type="button" class="flex justify-center items-center rounded cursor-pointer p-1 hover:bg-stone-200 dark:text-stone-200 dark:hover:bg-stone-700 md:hidden">
                        {{ svg('light/bars', ['fill-current', 'size-6']) }}
                    </button>
                </div>

                <!-- Desktop Navigation -->
                <div class="items-center gap-1.5 overflow-x-auto whitespace-nowrap hidden md:flex">
                    {% if pages %}
                        {% for slug, title in pages %}
                            <a href="{{ url_for('page', { slug: slug }) }}" class="nav-link">{{ title }}</a>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>

            <div class="flex items-center gap-1.5">
                <div class="flex items-center gap-1.5 bg-stone-200 rounded font-medium cursor-pointer text-stone-400 text-sm px-1.5 py-1 dark:bg-stone-700 dark:text-stone-500"
                    @keydown.ctrl.k.window.prevent="$dispatch('show-search')" @click="$dispatch('show-search')"
                >
                    {{ svg('light/magnifying-glass', ['fill-current', 'size-6', 'p-0.5']) }}

                    <div class="px-1">Search</div>

                    <div class="hidden md:block ml-2">
                        <kbd class="text-2xs">Ctrl K</kbd>
                    </div>
                </div>

                <div class="flex justify-end items-center gap-1.5">
                    {% include 'components/theme-toggle.twig' %}
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile Navigation -->
    <div x-show="open" class="container max-w-4xl border-double border-stone-800 border-b-4 text-stone-800 mx-auto px-4 py-2 transition dark:border-stone-200 dark:text-stone-200 md:hidden" x-transition.opacity>
        <div class="flex flex-col justify-between">
            {% if pages %}
                {% for slug, title in pages %}
                    <a href="{{ url_for('page', { slug: slug }) }}" class="nav-link">{{ title }}</a>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>
